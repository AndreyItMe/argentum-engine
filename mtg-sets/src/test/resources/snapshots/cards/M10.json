                    "type": "SpellCastEvent",
                    "spellFilter": {
                        "cardPredicates": [
                            {
                                "type": "Or",
                                "predicates": [
                                    {
                                        "type": "HasColor",
                                        "color": "BLUE"
                                    },
                                    {
                                        "type": "HasColor",
                                        "color": "BLACK"
                                    }
                                ]
                            }
                        ]
                    },
                    "player": "EachOpponent"
                },
                "binding": "ANY",
                "effect": {
                    "type": "Gated",
                    "gate": "Gate.MayDecide",
                    "then": {
                        "type": "AddCounters",
