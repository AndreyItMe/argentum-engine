                        "count": 1,
                        "target": "Self"
                    }
                }
            }
        ]
    },
    "metadata": {
        "collectorNumber": "194",
        "rarity": "UNCOMMON",
        "artist": "Matt Cavotta",
        "flavorText": "The more you struggle against its coils, the tighter they get.",
